# backend/.env
# Copy this file and fill in your real values.
# NEVER commit the real .env to version control.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=truepayid
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ── JWT Security ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_KEY_48_CHARS

# ── SMTP Email (Gmail example) ────────────────────────────
# For Gmail: enable 2FA, then generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# ── App ───────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ── Risk Thresholds ───────────────────────────────────────
HIGH_VALUE_THRESHOLD=10000.0
TOKEN_WINDOW_SECONDS=300

# ── CORS ──────────────────────────────────────────────────
# Add your production frontend domain here
ALLOWED_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
